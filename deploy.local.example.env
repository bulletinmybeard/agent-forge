# Local deploy settings — copy to deploy.local.env (gitignored) and edit.
# Sourced ONLY by scripts/deploy-local.sh. Kept separate from deploy.env (which
# is remote-tuned: host Redis, split dispatch, SSH host) so remote settings never
# leak into a single-host local run. All optional — with no file you get the full
# stack with bundled Qdrant/Redis. Dispatch is always in_process locally.

# Preset: light = web + one SAQ worker (+ redis/qdrant); full = + api/sidecar/dashboard.
AGENTFORGE_PRESET=light

# Reuse a service already running on your machine (brew etc.) instead of the
# bundled container. off (Qdrant only) skips the vector DB — RAG/@qdrant/semantic
# memory go quiet but the agent still runs.
AGENTFORGE_REDIS=container        # container | host
AGENTFORGE_QDRANT=container       # container | host | off
HOST_REDIS_URL=redis://host.docker.internal:6379
HOST_QDRANT_HOST=host.docker.internal
HOST_QDRANT_PORT=6333

# Raw profile override (rarely needed). Known: redis qdrant api sidecar dashboard
# AGENTFORGE_PROFILES=redis,qdrant
