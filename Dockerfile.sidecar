# agentforge-sidecar — hardened browser extraction service.
#
# Firefox in headed mode behind Xvfb with anti-bot evasion. Called by the
# web_fetch_rendered / monitor tools for extraction that needs stealth.
# Build context: repo root. Port: 8300.
FROM python:3.12-slim AS builder

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /build

RUN pip install --no-cache-dir \
    "fastapi>=0.115,<1" \
    "uvicorn[standard]>=0.34,<1" \
    "pydantic>=2,<3" \
    "playwright==1.56.0"

# ---------------------------------------------------------------------------
FROM python:3.12-slim AS runtime

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    DISPLAY=:99 \
    SIDECAR_HEADLESS=false \
    SIDECAR_BROWSER=firefox \
    PLAYWRIGHT_BROWSERS_PATH=/ms-playwright

WORKDIR /app

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        xvfb curl procps \
        libnss3 libnspr4 libatk1.0-0 libatk-bridge2.0-0 libcups2 libdrm2 \
        libdbus-1-3 libxkbcommon0 libxcomposite1 libxdamage1 libxfixes3 \
        libxrandr2 libgbm1 libpango-1.0-0 libcairo2 libasound2 libatspi2.0-0 \
        libwayland-client0 libgtk-3-0 libgdk-pixbuf-2.0-0 libpangocairo-1.0-0 \
        libcairo-gobject2 libxcursor1 \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /usr/local /usr/local

RUN playwright install firefox && \
    rm -rf /ms-playwright/.links /ms-playwright/*-driver && \
    find /ms-playwright -type d -name "chromium-*" -exec rm -rf {} + 2>/dev/null || true && \
    find /ms-playwright -type d -name "webkit-*" -exec rm -rf {} + 2>/dev/null || true

COPY sidecar/ ./sidecar/
COPY sidecar/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

EXPOSE 8300

HEALTHCHECK --interval=15s --timeout=5s --start-period=20s --retries=3 \
    CMD curl -f http://localhost:8300/health || exit 1

ENTRYPOINT ["/entrypoint.sh"]
CMD ["uvicorn", "sidecar.app:app", "--host", "0.0.0.0", "--port", "8300", "--workers", "2"]
