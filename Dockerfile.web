# agentforge-web — the headless backend (web/server): WebSocket + REST API,
# agent runners, SAQ queue. Port 8200. The SAQ workers reuse this same image
# with a different command (see docker-compose.yml).
FROM python:3.12-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl openssh-client git jq dnsutils iputils-ping net-tools procps \
    && rm -rf /var/lib/apt/lists/*

# GitHub CLI (used by the agent's gh_command tool)
RUN curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
      -o /usr/share/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
      > /etc/apt/sources.list.d/github-cli.list \
    && apt-get update && apt-get install -y --no-install-recommends gh \
    && rm -rf /var/lib/apt/lists/*

COPY pyproject.toml README.md ./
COPY agentforge/ agentforge/
RUN pip install --no-cache-dir ".[service]"

# Headless Firefox for web_fetch_rendered (Firefox = better TLS fingerprint)
ENV PLAYWRIGHT_BROWSERS_PATH=/ms-playwright
RUN playwright install-deps firefox \
    && playwright install firefox \
    && rm -rf /var/lib/apt/lists/*

# Application code + non-secret config (config.yaml / framework-config.yaml /
# profiles / user_context.md are bind-mounted at runtime).
COPY app/ app/
COPY web/ web/
# Glob picks up an optional custom_agents.local.yaml (private agents) when
# present — public checkouts only have custom_agents.yaml.
COPY tool_routing*.yaml custom_agents*.yaml skills.yaml ./
# Service-level instruction markdown: skills/ + custom-agent prompts.
COPY markdown/ markdown/
# Optional private tool plugins (gitignored modules baked when present; public
# checkouts have only the package scaffolding). Loaded via AGENTFORGE_TOOL_PLUGINS.
COPY plugins/ plugins/

RUN mkdir -p /app/data /app/data/uploads

EXPOSE 8200

CMD ["uvicorn", "web.server.app:app", "--host", "0.0.0.0", "--port", "8200"]
