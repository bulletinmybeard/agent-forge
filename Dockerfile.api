# agentforge-api — the RAG + search/indexing API (app/), port 8100.
FROM python:3.12-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends curl \
    && rm -rf /var/lib/apt/lists/*

COPY pyproject.toml README.md ./
COPY agentforge/ agentforge/
RUN pip install --no-cache-dir .

# Application code + non-secret config (real config.yaml / framework-config.yaml
# and profiles are bind-mounted at runtime by docker-compose).
COPY app/ app/
COPY tool_routing.yaml ./

RUN mkdir -p /app/data /app/chunks

EXPOSE 8100

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8100"]
